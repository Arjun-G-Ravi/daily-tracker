# Flask
FLASK_ENV=development
FLASK_DEBUG=1

# Supabase (required for auth + per-user API access)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
# Optional override for token verification issuer/jwks endpoint.
# SUPABASE_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
# SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
# For legacy HS256 projects only:
# SUPABASE_JWT_SECRET=YOUR_SUPABASE_LEGACY_JWT_SECRET

# SQLite path (local dev). On Vercel, defaults to /tmp/user_data.db
# NOTE: For persistent multi-user production storage, migrate to Postgres.
DATABASE_PATH=user_data.db
